---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found — TapToGen" description="The page you're looking for doesn't exist. Browse our generator tools or return to the homepage." canonical="/404/">
  <section class="page-hero" style="padding-bottom:40px;">
    <div class="container" style="text-align:center;">
      <div style="font-size:6rem;margin-bottom:24px;">🔍</div>
      <h1>404 — Page <span class="gradient-text">Not Found</span></h1>
      <p style="margin-bottom:32px;">The page you're looking for doesn't exist or has been moved.</p>
      <div class="hero-buttons" style="justify-content:center;">
        <a href="/" class="btn btn-primary">Go Home →</a>
        <a href="/tools/" class="btn btn-outline">Browse Tools</a>
      </div>
    </div>
  </section>
</BaseLayout>
