---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import { getRelatedTools, getToolBySlug, type Tool } from '@/data/tools';
import { noindexToolSlugs, pass20ControlMap } from '@/data/tool-page-data';
import { toolHubs } from '@/data/hubs';
import {
  createLocalizedFaqItems,
  createLocalizedGuide,
  getLanguageSwitchRoute,
  getLocalizedToolByCanonicalId,
  getLocalizedToolBySlug,
  getLocalizedPageCopy,
  getLocalizedSafetyNote,
  getLocalizedHubCopy,
  getLocalizedUiLabel,
  getToolLanguageAlternates,
  getSupportedLanguage,
  localizedPilotLanguages,
  frenchPilotTools,
} from '@/data/localization';

export const prerender = true;

export function getStaticPaths() {
  return frenchPilotTools
    .filter((entry) => !noindexToolSlugs.has(entry.canonicalToolId))
    .map((entry) => {
      const tool = getToolBySlug(entry.canonicalToolId);
      if (!tool) return null;
      return {
        params: { slug: entry.localizedSlug },
        props: { tool, localized: entry },
      };
    })
    .filter((path): path is { params: { slug: string }; props: { tool: Tool; localized: (typeof frenchPilotTools)[number] } } => path !== null);
}

interface Props {
  tool: Tool;
  localized: (typeof frenchPilotTools)[number];
}

const { tool, localized } = Astro.props;
const slug = tool.slug;

const resolvedLocalization = getLocalizedToolBySlug(Astro.params.slug || '', 'fr');
if (!resolvedLocalization || resolvedLocalization.canonicalToolId !== slug) {
  return Astro.redirect(getLanguageSwitchRoute(slug, 'en'));
}

const related = getRelatedTools(slug, 8).filter((item) => !noindexToolSlugs.has(item.slug)).slice(0, 4);
const matchingHub = toolHubs.find((hub) => hub.slug === tool.categorySlug || hub.categorySlugs.includes(tool.categorySlug));
const nextStepHubs = toolHubs
  .filter((hub) => hub.slug !== matchingHub?.slug && (matchingHub?.relatedHubSlugs.includes(hub.slug) || hub.relatedHubSlugs.includes(matchingHub?.slug || '')))
  .slice(0, 3);

const faqItems = createLocalizedFaqItems(localized);
const guideCopy = createLocalizedGuide(tool, localized);
const copy = getLocalizedPageCopy(localized);
const safetyNote = getLocalizedSafetyNote(localized);
const englishRoute = getLanguageSwitchRoute(slug, 'en');
const localizedRoute = getLanguageSwitchRoute(slug, 'fr');
const alternates = getToolLanguageAlternates(slug);

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": copy.h1,
  "url": `https://taptogen.com${localizedRoute}`,
  "description": copy.metaDescription,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "browserRequirements": "Requires JavaScript",
  "inLanguage": "fr"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://taptogen.com/fr/" },
    { "@type": "ListItem", "position": 2, "name": "Outils", "item": "https://taptogen.com/fr/tools/" },
    { "@type": "ListItem", "position": 3, "name": copy.h1, "item": `https://taptogen.com${localizedRoute}` }]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": "fr",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const pass20Controls = pass20ControlMap[slug];
---
<BaseLayout
  title={copy.metaTitle}
  description={copy.metaDescription}
  canonical={localizedRoute}
  schema={[toolSchema, breadcrumbSchema, faqSchema]}
  noindex={false}
  lang="fr"
  dir="ltr"
  alternates={alternates}
>
  <section class="tool-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Accueil</a><span class="sep">/</span>
        <a href="/tools/">Outils</a><span class="sep">/</span>
        <a href={`/tools/${tool.slug}/`}>Version anglaise</a><span class="sep">/</span>
        <span>{copy.h1}</span>
      </div>

      <div class="tool-page-header premium-tool-header">
        <span class="section-badge tool-category-badge">{tool.icon} {getLocalizedUiLabel(tool.category, 'fr')}</span>
        <h1>{copy.h1}</h1>
        <p>{copy.intro}</p>
        <nav class="language-switcher" aria-label="Sélecteur de langue">
          <a href={englishRoute} hreflang="en" lang="en">English</a>
          {localizedPilotLanguages.map((language) => (
            <a class={language === 'fr' ? 'active' : ''} href={getLanguageSwitchRoute(slug, language)} hreflang={language} lang={language}>{getSupportedLanguage(language).nativeName}</a>
          ))}
        </nav>
        <div class="tool-benefits" aria-label="Avantages de l’outil">
          <span>Gratuit</span>
          <span>Instantané</span>
          <span>Sans inscription</span>
          <span>Privé dans votre navigateur</span>
        </div>
      </div>

      <div class="tool-workspace premium-tool-workspace" id="tool-workspace" data-tool={tool.slug} data-type={tool.generatorType} data-format={tool.outputFormat || 'text'}>
        <div id="generator-ui">
          <div class="workspace-panel input-panel">
            <div class="panel-heading">
              <div>
                <span class="panel-kicker">Saisie</span>
                <h2>Personnalisez le résultat</h2>
              </div>
              <span class="generator-type-pill">{getLocalizedUiLabel(tool.generatorType.replace('-', ' '), 'fr')}</span>
            </div>

            {tool.toolOptions && tool.toolOptions.length > 0 && (
              <div class="tool-options-panel">
                {tool.toolOptions.map(opt => (
                  <div class="tool-option">
                    <label for={opt.id}>{getLocalizedUiLabel(opt.label, 'fr')}</label>
                    {opt.type === 'select' && (
                      <select id={opt.id} class="tool-select">
                        {opt.options?.map(o => (
                          <option value={o.value} selected={o.value === opt.default}>{getLocalizedUiLabel(o.label, 'fr')}</option>
                        ))}
                      </select>
                    )}
                    {opt.type === 'number' && (
                      <input type="number" id={opt.id} class="tool-number" value={typeof opt.default === 'number' || typeof opt.default === 'string' ? opt.default : undefined} min={opt.min} max={opt.max} />
                    )}
                    {opt.type === 'checkbox' && (
                      <div class="checkbox-option">
                        <input type="checkbox" id={opt.id} class="tool-checkbox" checked={!!opt.default} />
                        <span>Activé</span>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}

            {pass20Controls && (
              <div class="tool-options-panel">
                <div class="tool-option">
                  <label for={pass20Controls.modeId}>{getLocalizedUiLabel(pass20Controls.modeLabel, 'fr')}</label>
                  <select id={pass20Controls.modeId} class="tool-select">
                    {pass20Controls.modes.map(option => (
                      <option value={option.value}>{getLocalizedUiLabel(option.label, 'fr')}</option>
                    ))}
                  </select>
                </div>
                {pass20Controls.toneId && (
                  <div class="tool-option">
                    <label for={pass20Controls.toneId}>Ton</label>
                    <select id={pass20Controls.toneId} class="tool-select">
                      <option value="balanced">Équilibré</option>
                      <option value="polished">Soigné</option>
                      <option value="creative">Créatif</option>
                      <option value="friendly">Accessible</option>
                    </select>
                  </div>
                )}
                {pass20Controls.countId && (
                  <div class="tool-option">
                    <label for={pass20Controls.countId}>Nombre</label>
                    <input type="number" id={pass20Controls.countId} class="tool-number" value={pass20Controls.countDefault} min={pass20Controls.countMin} max={pass20Controls.countMax} />
                  </div>
                )}
              </div>
            )}

            <label class="input-label" for="tool-input">Prompt, mot-clé, texte ou détails</label>
            <textarea class="tool-input" id="tool-input" placeholder="Saisissez un mot-clé, un prompt ou un texte pour personnaliser ce générateur..." rows="4"></textarea>
            <div class="example-chip-row" aria-label="Exemples">
              <button type="button" class="example-chip" data-example={copy.primaryKeyword}>{copy.primaryKeyword}</button>
              {copy.faqTopics.slice(0, 2).map(keyword => (
                <button type="button" class="example-chip" data-example={keyword}>{keyword}</button>
              ))}
            </div>
            <div class="tool-controls premium-controls">
              <button class="btn btn-primary" id="generate-btn">Générer</button>
              <button class="btn btn-outline" id="example-btn">Utiliser un exemple</button>
              <button class="btn btn-ghost" id="reset-btn">Effacer</button>
          <button class="btn btn-ghost" id="regenerate-btn">Régénérer</button>
            </div>
          </div>

          <div class="workspace-panel output-panel">
            <div class="panel-heading">
              <div>
                <span class="panel-kicker">Résultat</span>
                <h2>Vos résultats</h2>
              </div>
              <button class="copy-btn copy-all-btn" id="copy-btn">Tout copier</button>
            </div>
            <div class="tool-output premium-output empty" id="tool-output">Vos résultats apparaîtront ici.</div>
          </div>
        </div>
      </div>

      {safetyNote && (
        <div class="tool-disclaimer" style="margin-top: 15px; padding: 15px; background: rgba(255, 193, 7, 0.1); border-left: 4px solid #ffc107; border-radius: 4px; font-size: 0.9rem; color: #b8860b;">
          <strong>Note:</strong> {safetyNote}
        </div>
      )}

            <div class="content-section premium-content-section">
        <section class="content-card intro-card">
          <h2>${locale === 'es' ? '¿Qué es' : locale === 'pt' ? 'O que é' : locale === 'fr' ? 'Qu\'est-ce que' : locale === 'de' ? 'Was ist' : locale === 'it' ? 'Che cos\'è' : locale === 'pl' ? 'Co to jest' : locale === 'ru' ? 'Что такое' : 'Nedir'} {copy.h1}?</h2>
          <p>{copy.metaDescription}</p>
          <p>{copy.intro}</p>
        </section>

        <section class="content-card">
          <h2>Principaux Avantages</h2>
          <ul>
            <li><strong>100% Gratuit</strong> - Sans abonnement, sans microtransaction et sans carte de crédit requise.</li>
            <li><strong>Confidentialité locale</strong> - Tout le traitement s'effectue sur votre appareil. Vos données restent privées.</li>
            <li><strong>Génération instantanée</strong> - Obtenez vos suggestions optimisées en quelques millisecondes seulement.</li>
            <li><strong>Sans inscription</strong> - Utilisez l'outil immédiatement sans créer de compte ni vous connecter.</li>
    </ul>
        </section>

        <section class="content-card">
          <h2>Caractéristiques de {copy.h1}</h2>
          <ul>
            <li><strong>Options interactives</strong> - Ajustez le ton, la quantité et le style directement depuis la console.</li>
            <li><strong>Copie rapide</strong> - Copiez des éléments individuels ou l'intégralité des résultats en un seul clic.</li>
            <li><strong>Format propre</strong> - Texte brut optimisé, prêt à être collé sans mise en forme parasite.</li>
    </ul>
        </section>

        <section class="content-card">
          <h2>${locale === 'es' ? 'Cómo usar' : locale === 'pt' ? 'Como usar' : locale === 'fr' ? 'Comment utiliser' : locale === 'de' ? 'Wie benutzt man' : locale === 'it' ? 'Come usare' : locale === 'pl' ? 'Jak używać' : locale === 'ru' ? 'Как использовать' : 'Nasıl Kullanılır'} {copy.h1}</h2>
          <ol>
            {guideCopy.howTo.map(step => <li>{step}</li>)}
          </ol>
        </section>

        <section class="content-card">
          <h2>${locale === 'es' ? 'Consejos para mejores resultados' : locale === 'pt' ? 'Dicas para obter melhores resultados' : locale === 'fr' ? 'Conseils pour de meilleurs résultats' : locale === 'de' ? 'Tipps für bessere Ergebnisse' : locale === 'it' ? 'Suggerimenti per risultati migliori' : locale === 'pl' ? 'Wskazówki dotyczące lepszych wyników' : locale === 'ru' ? 'Советы для получения лучших результатов' : 'Daha İyi Sonuçlar İçin İpuçları'}</h2>
          <ul>
            {guideCopy.tips.map(tip => <li><strong>{tip.title}</strong> - {tip.body}</li>)}
          </ul>
        </section>

        <section class="content-card">
          <h2>Bonnes Pratiques & Erreurs Courantes</h2>
          
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-top: 12px; margin-bottom: 6px; color: var(--color-text-primary);">Bonnes Pratiques</h3>
          <ul>
            <li><strong>Soyez précis</strong> - Ajoutez du contexte dans la zone d'entrée pour des résultats ciblés.</li>
            <li><strong>Variez les styles</strong> - Modifiez le ton ou la longueur pour trouver le meilleur compromis.</li>
            <li><strong>Révisez le texte</strong> - Considérez les résultats comme un brouillon de qualité à ajuster avant publication.</li>
          </ul>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-top: 16px; margin-bottom: 6px; color: var(--color-text-primary);">Erreurs Courantes</h3>
          <ul>
            <li><strong>Entrées trop vagues</strong> - Des termes isolés produisent des résultats trop génériques.</li>
            <li><strong>Absence de relecture</strong> - Ne pas vérifier la pertinence des noms ou des tags avant usage.</li>
            <li><strong>Oubli des réglages</strong> - Ne pas exploiter les curseurs de personnalisation disponibles.</li>
          </ul>
    
        </section>

        <section class="content-card" style="text-align: center; padding: 30px;">
          <h2>Essayez {copy.h1} maintenant !</h2>
          <p style="margin-bottom: 16px;">Prêt à optimiser votre temps ? Essayez {copy.h1} dès maintenant. Remplissez le formulaire ci-dessus et cliquez sur générer.</p>
          <a href="#" class="btn btn-primary" style="display: inline-block; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 600; color: #fff; background: var(--color-primary);">Accéder au générateur</a>
        </section>

        <section class="content-card">
          <h2>Comment utiliser {copy.h1}</h2>
          <ol>
            {guideCopy.howTo.map(step => <li>{step}</li>)}
          </ol>
        </section>

        <section class="content-card">
          <h2>Conseils pour de meilleurs résultats</h2>
          <ul>
            {guideCopy.tips.map(tip => <li><strong>{tip.title}</strong> - {tip.body}</li>)}
          </ul>
        </section>

        <section class="content-card">
          <h2>Pourquoi utiliser TapToGen ?</h2>
          <ul>
            <li><strong>Résultats instantanés</strong> - générez des idées directement dans votre navigateur.</li>
            <li><strong>Gratuit</strong> - sans inscription ni frais cachés.</li>
            <li><strong>Confidentialité pratique</strong> - le flux fonctionne sur la page sans demander de compte.</li>
            <li><strong>Relecture facile</strong> - copiez, comparez et adaptez avant utilisation.</li>
          </ul>
        </section>

        <section class="content-card">
          <h2>Questions fréquentes</h2>
          <div class="faq-list">
            {faqItems.map(faq => (
              <div class="faq-item">
                <button class="faq-question" aria-expanded="false">
                  <span>{faq.q}</span>
                  <span class="faq-icon">+</span>
                </button>
                <div class="faq-answer"><p>{faq.a}</p></div>
              </div>
            ))}
          </div>
        </section>

        {related.length > 0 && (
          <section class="content-card related-card">
            <h2>Outils associés</h2>
            <div class="tools-grid related-tools-grid">
              {related.map(r => (
                <a href={getLanguageSwitchRoute(r.slug, 'fr')} class="tool-card">
                  <div class="tool-icon">{r.icon}</div>
                  <h3>{getLocalizedToolByCanonicalId(r.slug, 'fr') ? getLocalizedPageCopy(getLocalizedToolByCanonicalId(r.slug, 'fr')!).h1 : r.name}</h3>
                  <p>{getLocalizedToolByCanonicalId(r.slug, 'fr') ? getLocalizedPageCopy(getLocalizedToolByCanonicalId(r.slug, 'fr')!).intro : r.tagline}</p>
                </a>
              ))}
            </div>
          </section>
        )}

        {(matchingHub || nextStepHubs.length > 0) && (
          <section class="content-card">
            <h2>Explorer d’autres outils TapToGen</h2>
            <p>Ces liens mènent vers des outils actifs et indexables.</p>
            <div class="category-grid">
              {matchingHub && (
                <a href={`/tools/${matchingHub.slug}/`} class="category-card">
                  <span class="cat-icon">#</span>
                  <h3>{getLocalizedHubCopy(matchingHub.slug, matchingHub.h1, matchingHub.description, 'fr').title}</h3>
                  <p>{getLocalizedHubCopy(matchingHub.slug, matchingHub.h1, matchingHub.description, 'fr').description}</p>
                </a>
              )}
              {nextStepHubs.map((hub) => (
                <a href={`/tools/${hub.slug}/`} class="category-card">
                  <span class="cat-icon">#</span>
                  <h3>{getLocalizedHubCopy(hub.slug, hub.h1, hub.description, 'fr').title}</h3>
                  <p>{getLocalizedHubCopy(hub.slug, hub.h1, hub.description, 'fr').description}</p>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </section>

  <script>
    import '@/scripts/tool-workspace';
  </script>
</BaseLayout>
