---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import { getBreadcrumbs } from '@/lib/search-breadcrumb';
import { tools, getRelatedTools, type Tool } from '@/data/tools';
import { getEffectiveGuideCopy, getNoindexSafetyProfile, noindexToolSlugs, pass20ControlMap } from '@/data/tool-page-data';
import { toolHubs } from '@/data/hubs';
import { getLanguageSwitchRoute, getLocalizedToolByCanonicalId, getSupportedLanguage, getToolLanguageAlternates, localizedPilotLanguages } from '@/data/localization';
import { toolConfigs } from '@/config';
import MetricsPanel from '@/components/MetricsPanel.astro';
import DownloadToolbar from '@/components/DownloadToolbar.astro';
import PreviewTabs from '@/components/PreviewTabs.astro';
import HistoryPanel from '@/components/HistoryPanel.astro';
import KeyboardShortcuts from '@/components/KeyboardShortcuts.astro';
import SchemaMarkup from '@/components/SchemaMarkup.astro';
import IntroSection from '@/components/IntroSection.astro';
import ExamplesSection from '@/components/ExamplesSection.astro';
import FaqSection from '@/components/FaqSection.astro';
import RelatedSection from '@/components/RelatedSection.astro';
import { getInternalLinks } from '@/lib/search-internal-links';

export const prerender = true;

export function getStaticPaths() {
  return tools.map(tool => ({
    params: { slug: tool.slug },
    props: { tool }}));
}

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const slug = tool.slug;
const toolConfig = toolConfigs[slug];

const internalLinks = getInternalLinks(Astro.url.pathname, 'en');
const matchingHub = toolHubs.find((hub) => hub.slug === tool.categorySlug || hub.categorySlugs.includes(tool.categorySlug));
const nextStepHubs = toolHubs
  .filter((hub) => hub.slug !== matchingHub?.slug && (matchingHub?.relatedHubSlugs.includes(hub.slug) || hub.relatedHubSlugs.includes(matchingHub?.slug || '')))
  .slice(0, 3);

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": tool.name,
  "url": `https://taptogen.com/tools/${tool.slug}/`,
  "description": tool.description.replace(/<[^>]*>/g, ''), // Strip HTML tags for JSON schema validity
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "browserRequirements": "Requires JavaScript"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://taptogen.com/" },
    { "@type": "ListItem", "position": 2, "name": "Tools", "item": "https://taptogen.com/tools/" },
    { "@type": "ListItem", "position": 3, "name": tool.name, "item": `https://taptogen.com/tools/${tool.slug}/` }]
};

const pass20Controls = pass20ControlMap[slug];

const noindexSafetyProfile = getNoindexSafetyProfile(slug);
const effectiveDisclaimer = tool.disclaimer || noindexSafetyProfile?.disclaimer || '';
const effectiveFaqItems = tool.faqItems.length > 0 ? tool.faqItems : noindexSafetyProfile ? [
  { q: `What is ${tool.name} best used for?`, a: noindexSafetyProfile.use },
  { q: `What should I avoid with ${tool.name}?`, a: noindexSafetyProfile.disclaimer },
  { q: `Does ${tool.name} verify official status, availability, compliance, or results?`, a: noindexSafetyProfile.limits },
  { q: `What should I check before using the output?`, a: noindexSafetyProfile.beforeUse }] : [];

const faqSchema = effectiveFaqItems.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": effectiveFaqItems.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a.replace(/<[^>]*>/g, '') } // Strip HTML for schema validity
  }))
} : null;

const schemas = [toolSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];

const effectiveGuideCopy = getEffectiveGuideCopy(tool);
const alternates = getToolLanguageAlternates(slug);
const localizedSwitchLanguages = localizedPilotLanguages.filter((language) => getLocalizedToolByCanonicalId(slug, language));
const breadcrumbs = getBreadcrumbs(Astro.url.pathname, 'en', tool.name);
---
<BaseLayout
  title={tool.metaTitle}
  description={tool.metaDescription}
  canonical={`/tools/${tool.slug}/`}
  schema={schemas}
  noindex={noindexToolSlugs.has(slug)}
  alternates={alternates}
>
  <section class="tool-page">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
          {breadcrumbs.map((item, idx) => (
            <>
              {idx > 0 && <li class="sep" aria-hidden="true">/</li>}
              <li>
                {item.isActive ? (
                  <span aria-current="page">{item.name}</span>
                ) : (
                  <a href={item.url}>{item.name}</a>
                )}
              </li>
            </>
          ))}
        </ol>
      </nav>

      <div class="tool-page-header premium-tool-header">
        <a href={`/categories/${tool.categorySlug}/`} class="section-badge tool-category-badge">{tool.icon} {tool.category}</a>
        <h1>{tool.name}</h1>
        <p>{tool.tagline}</p>
        <div class="tool-benefits" aria-label="Tool benefits">
          <span>Free</span>
          <span>Instant</span>
          <span>No signup</span>
          <span>Private in your browser</span>
        </div>
      </div>

      <!-- Generator Workspace -->
      <div class="tool-workspace premium-tool-workspace" id="tool-workspace" data-tool={tool.slug} data-type={tool.generatorType} data-format={tool.outputFormat || 'text'}>
        <div id="generator-ui">
          <div class="workspace-panel input-panel">
            <div class="panel-heading">
              <div>
                <span class="panel-kicker">Input</span>
                <h2>Customize Your Result</h2>
              </div>
              <span class="generator-type-pill">{tool.generatorType.replace('-', ' ')}</span>
            </div>

            {tool.toolOptions && tool.toolOptions.length > 0 && (
              <div class="tool-options-panel">
                {tool.toolOptions.map(opt => (
                  <div class="tool-option">
                    <label for={opt.id}>{opt.label}</label>
                    {opt.type === 'select' && (
                      <select id={opt.id} class="tool-select">
                        {opt.options?.map(o => (
                          <option value={o.value} selected={o.value === opt.default}>{o.label}</option>
                        ))}
                      </select>
                    )}
                    {opt.type === 'number' && (
                      <input type="number" id={opt.id} class="tool-number" value={typeof opt.default === 'number' || typeof opt.default === 'string' ? opt.default : undefined} min={opt.min} max={opt.max} />
                    )}
                    {opt.type === 'checkbox' && (
                      <div class="checkbox-option">
                        <input type="checkbox" id={opt.id} class="tool-checkbox" checked={!!opt.default} />
                        <span>Enabled</span>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}

            {pass20Controls && (
              <div class="tool-options-panel">
                <div class="tool-option">
                  <label for={pass20Controls.modeId}>{pass20Controls.modeLabel}</label>
                  <select id={pass20Controls.modeId} class="tool-select">
                    {pass20Controls.modes.map(option => (
                      <option value={option.value}>{option.label}</option>
                    ))}
                  </select>
                </div>
                {pass20Controls.toneId && (
                  <div class="tool-option">
                    <label for={pass20Controls.toneId}>Tone</label>
                    <select id={pass20Controls.toneId} class="tool-select">
                      <option value="balanced">Balanced</option>
                      <option value="polished">Polished</option>
                      <option value="creative">Creative</option>
                      <option value="friendly">Friendly</option>
                    </select>
                  </div>
                )}
                {pass20Controls.countId && (
                  <div class="tool-option">
                    <label for={pass20Controls.countId}>Result Count</label>
                    <input type="number" id={pass20Controls.countId} class="tool-number" value={pass20Controls.countDefault} min={pass20Controls.countMin} max={pass20Controls.countMax} />
                  </div>
                )}
              </div>
            )}

            <label class="input-label" for="tool-input">Prompt, keyword, text, or details</label>
            {toolConfig && (toolConfig.counters.chars || toolConfig.counters.glyphs || toolConfig.counters.words || toolConfig.counters.lines) && (
              <div class="casing-toolbar" style="margin-bottom: 8px; display: flex; gap: 8px; flex-wrap: wrap; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--color-border); padding-bottom: 8px;">
                <div style="display: flex; gap: 6px;">
                  <button type="button" class="btn btn-ghost" id="btn-case-lower" style="padding: 4px 8px; font-size: 0.75rem; border-radius: 4px; font-weight: 500; min-height: 28px;">lowercase</button>
                  <button type="button" class="btn btn-ghost" id="btn-case-upper" style="padding: 4px 8px; font-size: 0.75rem; border-radius: 4px; font-weight: 500; min-height: 28px;">UPPERCASE</button>
                  <button type="button" class="btn btn-ghost" id="btn-case-title" style="padding: 4px 8px; font-size: 0.75rem; border-radius: 4px; font-weight: 500; min-height: 28px;">Title Case</button>
                  <button type="button" class="btn btn-ghost" id="btn-case-sentence" style="padding: 4px 8px; font-size: 0.75rem; border-radius: 4px; font-weight: 500; min-height: 28px;">Sentence case</button>
                  {toolConfig.slug === 'fancy-text-generator' && (
                    <button type="button" class="btn btn-ghost" id="btn-case-random-style" style="padding: 4px 8px; font-size: 0.75rem; border-radius: 4px; font-weight: 500; min-height: 28px; color: var(--color-accent-2);">🎲 Random</button>
                  )}
                </div>
                <MetricsPanel chars={toolConfig.counters.chars} glyphs={toolConfig.counters.glyphs} words={toolConfig.counters.words} lines={toolConfig.counters.lines} />
              </div>
            )}
            <textarea class="tool-input" id="tool-input" placeholder="Enter a keyword, prompt, or text to customize this generator..." rows="4"></textarea>
            <div class="example-chip-row" aria-label="Example prompts">
              <button type="button" class="example-chip" data-example={tool.primaryKeyword}>{tool.primaryKeyword}</button>
              {tool.secondaryKeywords.slice(0, 2).map(keyword => (
                <button type="button" class="example-chip" data-example={keyword}>{keyword}</button>
              ))}
            </div>
            {toolConfig && toolConfig.shortcuts && (
              <KeyboardShortcuts shortcuts={toolConfig.shortcuts} />
            )}
            <div class="tool-controls premium-controls">
              <button class="btn btn-primary" id="generate-btn">Generate</button>
              <button class="btn btn-outline" id="example-btn">Use Example</button>
              <button class="btn btn-ghost" id="reset-btn">Clear</button>
              <button class="btn btn-ghost" id="regenerate-btn">Regenerate</button>
              <button class="btn btn-ghost" id="undo-btn" aria-label="Undo last change" title="Undo" disabled style="opacity: 0.5;">↩ Undo</button>
              <button class="btn btn-ghost" id="redo-btn" aria-label="Redo last change" title="Redo" disabled style="opacity: 0.5;">↪ Redo</button>
              <button class="btn btn-ghost" id="share-btn" aria-label="Share this tool" title="Share">🔗 Share</button>
            </div>
          </div>

          <div class="workspace-panel output-panel">
            <div class="panel-heading">
              <div>
                <span class="panel-kicker">Output</span>
                <h2>Your Results</h2>
              </div>
              <button class="copy-btn copy-all-btn" id="copy-btn">Copy All</button>
            </div>
            {toolConfig && (toolConfig.search || toolConfig.exporters.length > 0) && (
              <div class="style-search-container" style="margin-bottom: 12px; display: none;" id="style-search-container">
                <div style="display: flex; gap: 8px; align-items: center; width: 100%; flex-wrap: wrap;">
                  {toolConfig.search && (
                    <input type="text" id={`${toolConfig.slug.split('-')[0]}-style-search`} placeholder={`Search ${toolConfig.slug === 'fancy-text-generator' ? '50+' : ''} styles...`} style="flex: 1; min-width: 200px; padding: 8px 12px; border-radius: 8px; border: 1px solid var(--color-border); background: var(--color-bg-secondary); color: var(--color-text-primary); font-size: 0.85rem; outline: none; transition: var(--transition);" />
                  )}
                  {toolConfig.shuffle && (
                    <button type="button" class="btn btn-ghost" id="btn-shuffle-styles" style="padding: 8px 12px; font-size: 0.8rem; border-radius: 8px; min-height: 35px; white-space: nowrap;">🔀 Shuffle</button>
                  )}
                  <DownloadToolbar exporters={toolConfig.exporters} />
                </div>
              </div>
            )}
            <div class="tool-output premium-output empty" id="tool-output">Your generated results will appear here.</div>
            {toolConfig && (toolConfig.previews.length > 0 || toolConfig.history) && (
              <div class={`${toolConfig.slug.split('-')[0]}-premium-extensions`} style="display: none;" id={`${toolConfig.slug.split('-')[0]}-extensions-container`}>
                <PreviewTabs previews={toolConfig.previews} placeholder={toolConfig.slug === 'fancy-text-generator' ? 'Your fancy text...' : 'Your bold text...'} />
                <HistoryPanel enabled={toolConfig.history} prefix={toolConfig.slug.split('-')[0]} />
              </div>
            )}
          </div>
        </div>
      </div>

      {effectiveDisclaimer && (
        <div class="tool-disclaimer" style="margin-top: 16px; padding: 16px 20px; background: rgba(251, 191, 36, 0.08); border-left: 3px solid rgba(251, 191, 36, 0.6); border-radius: 8px; font-size: 0.9rem; color: #d4a843;">
          <strong>Disclaimer:</strong> {effectiveDisclaimer}
        </div>
      )}

      <!-- Content Below Tool -->
      <div class="content-section premium-content-section">
        <IntroSection h1={tool.name} metaDescription={tool.tagline} intro={tool.description} whatIsText="What is" />

        <section class="content-card">
          <h2>How to Use {tool.name}</h2>
          {effectiveGuideCopy ? (
            <ol>
              {effectiveGuideCopy.howTo.map(step => <li>{step}</li>)}
            </ol>
          ) : (
            <ol>
              <li>Enter your text, keyword, or details in the input field.</li>
              <li>Adjust any options to match the style or format you need.</li>
              <li>Click Generate to create fresh results.</li>
              <li>Copy one result, a section, or the full output.</li>
            </ol>
          )}
        </section>

        <section class="content-card">
          <h2>Tips for Better Results</h2>
          {effectiveGuideCopy ? (
            <ul>
              {effectiveGuideCopy.tips.map(tip => <li><strong>{tip.title}</strong> - {tip.body}</li>)}
            </ul>
          ) : (
            <ul>
              <li><strong>Be specific</strong> - a clear keyword or short brief usually gives stronger output.</li>
              <li><strong>Try variations</strong> - regenerate a few times to compare different directions.</li>
              <li><strong>Use options</strong> - style, tone, count, and format settings can change the result quickly.</li>
              <li><strong>Copy selectively</strong> - use individual copy buttons when you only need one card or section.</li>
            </ul>
          )}
        </section>

        <FaqSection faqTitle="Frequently Asked Questions" faqItems={effectiveFaqItems.map(f => ({ question: f.q, answer: f.a }))} />

        <RelatedSection title="Related Tools" links={internalLinks} />

        {(matchingHub || nextStepHubs.length > 0) && (
          <section class="content-card">
            <h2>Explore More TapToGen Tools</h2>
            <p>Use these hub links to move from this generator into related active, indexable TapToGen discovery pages.</p>
            <div class="category-grid">
              {matchingHub && (
                <a href={`/tools/${matchingHub.slug}/`} class="category-card">
                  <span class="cat-icon">#</span>
                  <h3>{matchingHub.h1}</h3>
                  <p>{matchingHub.description}</p>
                </a>
              )}
              {nextStepHubs.map((hub) => (
                <a href={`/tools/${hub.slug}/`} class="category-card">
                  <span class="cat-icon">#</span>
                  <h3>{hub.h1}</h3>
                  <p>{hub.description}</p>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </section>
  <script>
    import '@/scripts/tool-workspace';
  </script>
</BaseLayout>
