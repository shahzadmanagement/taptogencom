---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
---
<BaseLayout title="Blog — TapToGen" description="Read helpful articles about generator tools, creative naming, social media tips, SEO strategies, and more on the TapToGen blog." canonical="/blog/">
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a><span class="sep">›</span><span>Blog</span></div>
      <span class="section-badge">📖 Blog</span>
      <h1>TapToGen <span class="gradient-text">Blog</span></h1>
      <p>Tips, guides, and insights about generator tools, naming, social media, and SEO</p>
    </div>
  </section>
  <div class="container">
    <div style="text-align:center;padding:80px 0;color:var(--color-text-muted);">
      <p style="font-size:3rem;margin-bottom:16px;">📝</p>
      <h2>Coming Soon</h2>
      <p style="margin-top:12px;">We're working on amazing content. Check back soon for helpful articles and guides!</p>
      <a href="/tools/" class="btn btn-primary" style="margin-top:24px;">Explore Tools Instead →</a>
    </div>
  </div>
</BaseLayout>
