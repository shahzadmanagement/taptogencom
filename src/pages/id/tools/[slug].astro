---
import LocalizedToolPage from '@/components/LocalizedToolPage.astro';
import { getToolBySlug, type Tool } from '@/data/tools';
import { noindexToolSlugs } from '@/data/tool-page-data';
import {
  getLanguageSwitchRoute,
  getLocalizedToolBySlug,
  indonesianPilotTools,
} from '@/data/localization';

export const prerender = true;

export function getStaticPaths() {
  return indonesianPilotTools
    .filter((entry) => !noindexToolSlugs.has(entry.canonicalToolId))
    .map((entry) => {
      const tool = getToolBySlug(entry.canonicalToolId);
      if (!tool) return null;
      return {
        params: { slug: entry.localizedSlug },
        props: { tool, localized: entry },
      };
    })
    .filter((path): path is { params: { slug: string }; props: { tool: Tool; localized: (typeof indonesianPilotTools)[number] } } => path !== null);
}

interface Props {
  tool: Tool;
  localized: (typeof indonesianPilotTools)[number];
}

const { tool, localized } = Astro.props;
const resolvedLocalization = getLocalizedToolBySlug(Astro.params.slug || '', 'id');
if (!resolvedLocalization || resolvedLocalization.canonicalToolId !== tool.slug) {
  return Astro.redirect(getLanguageSwitchRoute(tool.slug, 'en'));
}
---
<LocalizedToolPage tool={tool} localized={localized} language="id" />
