---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import { categories } from '@/data/categories';
---
<BaseLayout
  title="Generator Tool Categories — TapToGen"
  description="Browse all generator tool categories. Name generators, text & font tools, social media generators, SEO tools, business generators, and more."
  canonical="/categories/"
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a><span class="sep">›</span><span>Categories</span>
      </div>
      <span class="section-badge">📂 Categories</span>
      <h1>Generator Tool <span class="gradient-text">Categories</span></h1>
      <p>Explore our organized collection of {categories.length} tool categories</p>
    </div>
  </section>

  <section class="tools-section" style="padding-top:0;">
    <div class="container">
      <div class="category-grid">
        {categories.map(cat => (
          <a href={`/categories/${cat.slug}/`} class="category-card">
            <span class="cat-icon">{cat.icon}</span>
            <h3>{cat.name}</h3>
            <p>{cat.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
