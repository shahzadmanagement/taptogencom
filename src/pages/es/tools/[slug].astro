---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import { getRelatedTools, getToolBySlug, type Tool } from '@/data/tools';
import { noindexToolSlugs, pass20ControlMap } from '@/data/tool-page-data';
import { toolHubs } from '@/data/hubs';
import {
  createSpanishFaqItems,
  createSpanishGuide,
  getLanguageSwitchRoute,
  getLocalizedToolByCanonicalId,
  getLocalizedToolBySlug,
  getSpanishPageCopy,
  getSpanishSafetyNote,
  getSpanishHubCopy,
  getSpanishUiLabel,
  getSupportedLanguage,
  getToolLanguageAlternates,
  localizedPilotLanguages,
  spanishPilotTools,
} from '@/data/localization';

export const prerender = true;

export function getStaticPaths() {
  return spanishPilotTools
    .filter((entry) => !noindexToolSlugs.has(entry.canonicalToolId))
    .map((entry) => {
      const tool = getToolBySlug(entry.canonicalToolId);
      if (!tool) return null;
      return {
        params: { slug: entry.localizedSlug },
        props: { tool, localized: entry },
      };
    })
    .filter((path): path is { params: { slug: string }; props: { tool: Tool; localized: (typeof spanishPilotTools)[number] } } => path !== null);
}

interface Props {
  tool: Tool;
  localized: (typeof spanishPilotTools)[number];
}

const { tool, localized } = Astro.props;
const slug = tool.slug;

const resolvedLocalization = getLocalizedToolBySlug(Astro.params.slug || '', 'es');
if (!resolvedLocalization || resolvedLocalization.canonicalToolId !== slug) {
  return Astro.redirect(getLanguageSwitchRoute(slug, 'en'));
}

const related = getRelatedTools(slug, 8).filter((item) => !noindexToolSlugs.has(item.slug)).slice(0, 4);
const matchingHub = toolHubs.find((hub) => hub.slug === tool.categorySlug || hub.categorySlugs.includes(tool.categorySlug));
const nextStepHubs = toolHubs
  .filter((hub) => hub.slug !== matchingHub?.slug && (matchingHub?.relatedHubSlugs.includes(hub.slug) || hub.relatedHubSlugs.includes(matchingHub?.slug || '')))
  .slice(0, 3);

const faqItems = createSpanishFaqItems(localized);
const guideCopy = createSpanishGuide(tool, localized);
const copy = getSpanishPageCopy(localized);
const safetyNote = getSpanishSafetyNote(localized);
const englishRoute = getLanguageSwitchRoute(slug, 'en');
const spanishRoute = getLanguageSwitchRoute(slug, 'es');
const alternates = getToolLanguageAlternates(slug);

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": copy.h1,
  "url": `https://taptogen.com${spanishRoute}`,
  "description": copy.metaDescription,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "browserRequirements": "Requires JavaScript",
  "inLanguage": "es"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://taptogen.com/es/" },
    { "@type": "ListItem", "position": 2, "name": "Herramientas", "item": "https://taptogen.com/es/tools/" },
    { "@type": "ListItem", "position": 3, "name": copy.h1, "item": `https://taptogen.com${spanishRoute}` }]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": "es",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const pass20Controls = pass20ControlMap[slug];
---
<BaseLayout
  title={copy.metaTitle}
  description={copy.metaDescription}
  canonical={spanishRoute}
  schema={[toolSchema, breadcrumbSchema, faqSchema]}
  noindex={false}
  lang="es"
  dir="ltr"
  alternates={alternates}
>
  <section class="tool-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Inicio</a><span class="sep">/</span>
        <a href="/tools/">Herramientas</a><span class="sep">/</span>
        <a href={`/tools/${tool.slug}/`}>Versión en inglés</a><span class="sep">/</span>
        <span>{copy.h1}</span>
      </div>

      <div class="tool-page-header premium-tool-header">
        <span class="section-badge tool-category-badge">{tool.icon} {getSpanishUiLabel(tool.category)}</span>
        <h1>{copy.h1}</h1>
        <p>{copy.intro}</p>
        <nav class="language-switcher" aria-label="Selector de idioma">
          <a href={englishRoute} hreflang="en" lang="en">English</a>
          {localizedPilotLanguages.map((language) => (
            <a class={language === 'es' ? 'active' : ''} href={getLanguageSwitchRoute(slug, language)} hreflang={language} lang={language}>{getSupportedLanguage(language).nativeName}</a>
          ))}
        </nav>
        <div class="tool-benefits" aria-label="Ventajas de la herramienta">
          <span>Gratis</span>
          <span>Instantáneo</span>
          <span>Sin registro</span>
          <span>Privado en tu navegador</span>
        </div>
      </div>

      <div class="tool-workspace premium-tool-workspace" id="tool-workspace" data-tool={tool.slug} data-type={tool.generatorType} data-format={tool.outputFormat || 'text'}>
        <div id="generator-ui">
          <div class="workspace-panel input-panel">
            <div class="panel-heading">
              <div>
                <span class="panel-kicker">Entrada</span>
                <h2>Personaliza tu resultado</h2>
              </div>
              <span class="generator-type-pill">{getSpanishUiLabel(tool.generatorType.replace('-', ' '))}</span>
            </div>

            {tool.toolOptions && tool.toolOptions.length > 0 && (
              <div class="tool-options-panel">
                {tool.toolOptions.map(opt => (
                  <div class="tool-option">
                    <label for={opt.id}>{getSpanishUiLabel(opt.label)}</label>
                    {opt.type === 'select' && (
                      <select id={opt.id} class="tool-select">
                        {opt.options?.map(o => (
                          <option value={o.value} selected={o.value === opt.default}>{getSpanishUiLabel(o.label)}</option>
                        ))}
                      </select>
                    )}
                    {opt.type === 'number' && (
                      <input type="number" id={opt.id} class="tool-number" value={typeof opt.default === 'number' || typeof opt.default === 'string' ? opt.default : undefined} min={opt.min} max={opt.max} />
                    )}
                    {opt.type === 'checkbox' && (
                      <div class="checkbox-option">
                        <input type="checkbox" id={opt.id} class="tool-checkbox" checked={!!opt.default} />
                        <span>Activado</span>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}

            {pass20Controls && (
              <div class="tool-options-panel">
                <div class="tool-option">
                  <label for={pass20Controls.modeId}>{getSpanishUiLabel(pass20Controls.modeLabel)}</label>
                  <select id={pass20Controls.modeId} class="tool-select">
                    {pass20Controls.modes.map(option => (
                      <option value={option.value}>{getSpanishUiLabel(option.label)}</option>
                    ))}
                  </select>
                </div>
                {pass20Controls.toneId && (
                  <div class="tool-option">
                    <label for={pass20Controls.toneId}>Tono</label>
                    <select id={pass20Controls.toneId} class="tool-select">
                      <option value="balanced">Equilibrado</option>
                      <option value="polished">Pulido</option>
                      <option value="creative">Creativo</option>
                      <option value="friendly">Cercano</option>
                    </select>
                  </div>
                )}
                {pass20Controls.countId && (
                  <div class="tool-option">
                    <label for={pass20Controls.countId}>Cantidad</label>
                    <input type="number" id={pass20Controls.countId} class="tool-number" value={pass20Controls.countDefault} min={pass20Controls.countMin} max={pass20Controls.countMax} />
                  </div>
                )}
              </div>
            )}

            <label class="input-label" for="tool-input">Prompt, palabra clave, texto o detalles</label>
            <textarea class="tool-input" id="tool-input" placeholder="Escribe una palabra clave, prompt o texto para personalizar este generador..." rows="4"></textarea>
            <div class="example-chip-row" aria-label="Ejemplos">
              <button type="button" class="example-chip" data-example={copy.primaryKeyword}>{copy.primaryKeyword}</button>
              {copy.faqTopics.slice(0, 2).map(keyword => (
                <button type="button" class="example-chip" data-example={keyword}>{keyword}</button>
              ))}
            </div>
            <div class="tool-controls premium-controls">
              <button class="btn btn-primary" id="generate-btn">Generar</button>
              <button class="btn btn-outline" id="example-btn">Usar ejemplo</button>
              <button class="btn btn-ghost" id="reset-btn">Borrar</button>
              <button class="btn btn-ghost" id="regenerate-btn">Regenerar</button>
            </div>
          </div>

          <div class="workspace-panel output-panel">
            <div class="panel-heading">
              <div>
                <span class="panel-kicker">Salida</span>
                <h2>Tus resultados</h2>
              </div>
              <button class="copy-btn copy-all-btn" id="copy-btn">Copiar todo</button>
            </div>
            <div class="tool-output premium-output empty" id="tool-output">Tus resultados aparecerán aquí.</div>
          </div>
        </div>
      </div>

      {safetyNote && (
        <div class="tool-disclaimer" style="margin-top: 15px; padding: 15px; background: rgba(255, 193, 7, 0.1); border-left: 4px solid #ffc107; border-radius: 4px; font-size: 0.9rem; color: #b8860b;">
          <strong>Nota:</strong> {safetyNote}
        </div>
      )}

            <div class="content-section premium-content-section">
        <section class="content-card intro-card">
          <h2>${locale === 'es' ? '¿Qué es' : locale === 'pt' ? 'O que é' : locale === 'fr' ? 'Qu\'est-ce que' : locale === 'de' ? 'Was ist' : locale === 'it' ? 'Che cos\'è' : locale === 'pl' ? 'Co to jest' : locale === 'ru' ? 'Что такое' : 'Nedir'} {copy.h1}?</h2>
          <p>{copy.metaDescription}</p>
          <p>{copy.intro}</p>
        </section>

        <section class="content-card">
          <h2>Ventajas principales</h2>
          <ul>
            <li><strong>100% Gratis</strong> - Sin suscripciones, sin microtransacciones y sin necesidad de tarjeta de crédito.</li>
            <li><strong>Privacidad en el navegador</strong> - Todo el procesamiento se realiza localmente en tu ordenador. Tus datos nunca salen de tu navegador.</li>
            <li><strong>Generación instantánea</strong> - Obtén una lista de sugerencias optimizadas en milisegundos.</li>
            <li><strong>Sin registro</strong> - Empieza a usar la utilidad inmediatamente sin crear una cuenta ni iniciar sesión.</li>
    </ul>
        </section>

        <section class="content-card">
          <h2>Características de {copy.h1}</h2>
          <ul>
            <li><strong>Ajustes interactivos</strong> - Personaliza la configuración de tono, cantidad y estilo directamente desde el panel de control.</li>
            <li><strong>Copia en un clic</strong> - Copia elementos individuales o copia todos los resultados al instante con acciones de portapapeles integradas.</li>
            <li><strong>Formato limpio</strong> - Produce texto listo para copiar sin etiquetas de marcado, preparado para pegar en cualquier lugar.</li>
    </ul>
        </section>

        <section class="content-card">
          <h2>${locale === 'es' ? 'Cómo usar' : locale === 'pt' ? 'Como usar' : locale === 'fr' ? 'Comment utiliser' : locale === 'de' ? 'Wie benutzt man' : locale === 'it' ? 'Come usare' : locale === 'pl' ? 'Jak używać' : locale === 'ru' ? 'Как использовать' : 'Nasıl Kullanılır'} {copy.h1}</h2>
          <ol>
            {guideCopy.howTo.map(step => <li>{step}</li>)}
          </ol>
        </section>

        <section class="content-card">
          <h2>${locale === 'es' ? 'Consejos para mejores resultados' : locale === 'pt' ? 'Dicas para obter melhores resultados' : locale === 'fr' ? 'Conseils pour de meilleurs résultats' : locale === 'de' ? 'Tipps für bessere Ergebnisse' : locale === 'it' ? 'Suggerimenti per risultati migliori' : locale === 'pl' ? 'Wskazówki dotyczące lepszych wyników' : locale === 'ru' ? 'Советы для получения лучших результатов' : 'Daha İyi Sonuçlar İçin İpuçları'}</h2>
          <ul>
            {guideCopy.tips.map(tip => <li><strong>{tip.title}</strong> - {tip.body}</li>)}
          </ul>
        </section>

        <section class="content-card">
          <h2>Buenas prácticas y errores comunes</h2>
          
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-top: 12px; margin-bottom: 6px; color: var(--color-text-primary);">Buenas prácticas</h3>
          <ul>
            <li><strong>Proporciona una entrada clara</strong> - Introduce tanto contexto como sea posible en el cuadro de entrada para obtener resultados muy relevantes.</li>
            <li><strong>Explora diferentes estilos</strong> - Prueba a cambiar opciones como el tono o la estructura para encontrar la salida perfecta.</li>
            <li><strong>Revisa y pule</strong> - Trata el resultado generado como un borrador de alta calidad y revísalo para alinearlo con tus objetivos antes de publicarlo.</li>
          </ul>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-top: 16px; margin-bottom: 6px; color: var(--color-text-primary);">Errores comunes a evitar</h3>
          <ul>
            <li><strong>Entradas vagas</strong> - Introducir entradas genéricas de una sola palabra puede dar lugar a sugerencias menos especializadas.</li>
            <li><strong>Omitir la revisión</strong> - No verificar los nombres, etiquetas o textos personalizados antes de publicarlos puede provocar conflictos de marca o políticas.</li>
            <li><strong>Ignorar los ajustes</strong> - Olvidar alternar las opciones de tono o formato puede causar desalineación en el resultado.</li>
          </ul>
    
        </section>

        <section class="content-card" style="text-align: center; padding: 30px;">
          <h2>¡Prueba {copy.h1} ahora!</h2>
          <p style="margin-bottom: 16px;">¿Listo para optimizar tu flujo de trabajo? Prueba {copy.h1} ahora. Simplemente sube de nuevo a la consola interactiva, introduce tus detalles y toca generar para empezar de inmediato.</p>
          <a href="#" class="btn btn-primary" style="display: inline-block; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 600; color: #fff; background: var(--color-primary);">Ir al generador</a>
        </section>

        <section class="content-card">
          <h2>Cómo usar {copy.h1}</h2>
          <ol>
            {guideCopy.howTo.map(step => <li>{step}</li>)}
          </ol>
        </section>

        <section class="content-card">
          <h2>Consejos para mejores resultados</h2>
          <ul>
            {guideCopy.tips.map(tip => <li><strong>{tip.title}</strong> - {tip.body}</li>)}
          </ul>
        </section>

        <section class="content-card">
          <h2>¿Por qué usar TapToGen?</h2>
          <ul>
            <li><strong>Resultados instantáneos</strong> - genera ideas en tu navegador.</li>
            <li><strong>Gratis</strong> - sin registro ni costes ocultos.</li>
            <li><strong>Privacidad práctica</strong> - el flujo de la herramienta funciona en la página sin pedir una cuenta.</li>
            <li><strong>Revisión fácil</strong> - copia, compara y edita antes de usar el resultado.</li>
          </ul>
        </section>

        <section class="content-card">
          <h2>Preguntas frecuentes</h2>
          <div class="faq-list">
            {faqItems.map(faq => (
              <div class="faq-item">
                <button class="faq-question" aria-expanded="false">
                  <span>{faq.q}</span>
                  <span class="faq-icon">+</span>
                </button>
                <div class="faq-answer"><p>{faq.a}</p></div>
              </div>
            ))}
          </div>
        </section>

        {related.length > 0 && (
          <section class="content-card related-card">
            <h2>Herramientas relacionadas</h2>
            <div class="tools-grid related-tools-grid">
              {related.map(r => (
                <a href={getLanguageSwitchRoute(r.slug, 'es')} class="tool-card">
                  <div class="tool-icon">{r.icon}</div>
                  <h3>{getLocalizedToolByCanonicalId(r.slug, 'es') ? getSpanishPageCopy(getLocalizedToolByCanonicalId(r.slug, 'es')!).h1 : r.name}</h3>
                  <p>{getLocalizedToolByCanonicalId(r.slug, 'es') ? getSpanishPageCopy(getLocalizedToolByCanonicalId(r.slug, 'es')!).intro : r.tagline}</p>
                </a>
              ))}
            </div>
          </section>
        )}

        {(matchingHub || nextStepHubs.length > 0) && (
          <section class="content-card">
            <h2>Explora más herramientas de TapToGen</h2>
            <p>Estos enlaces mantienen la navegación en herramientas activas e indexables.</p>
            <div class="category-grid">
              {matchingHub && (
                <a href={`/tools/${matchingHub.slug}/`} class="category-card">
                  <span class="cat-icon">#</span>
                  <h3>{getSpanishHubCopy(matchingHub.slug, matchingHub.h1, matchingHub.description).title}</h3>
                  <p>{getSpanishHubCopy(matchingHub.slug, matchingHub.h1, matchingHub.description).description}</p>
                </a>
              )}
              {nextStepHubs.map((hub) => (
                <a href={`/tools/${hub.slug}/`} class="category-card">
                  <span class="cat-icon">#</span>
                  <h3>{getSpanishHubCopy(hub.slug, hub.h1, hub.description).title}</h3>
                  <p>{getSpanishHubCopy(hub.slug, hub.h1, hub.description).description}</p>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </section>

  <script>
    import '@/scripts/tool-workspace';
  </script>
</BaseLayout>
