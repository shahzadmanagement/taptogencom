---
import BaseLayout from 'theme/layouts/BaseLayout.astro';
import { toolHubs, type ToolHub } from '@/data/hubs';
import { tools, getToolBySlug, type Tool } from '@/data/tools';
import { noindexToolSlugs } from '@/data/tool-page-data';

interface Props {
  hub: ToolHub;
}

const { hub } = Astro.props;
const noindex = new Set(noindexToolSlugs);
const featured = hub.featuredToolSlugs
  .map((slug) => getToolBySlug(slug))
  .filter((tool): tool is Tool => {
    if (!tool) return false;
    return !noindex.has(tool.slug);
  });
const fillTools = tools
  .filter((tool) => hub.categorySlugs.includes(tool.categorySlug) && !noindex.has(tool.slug) && !featured.some((item) => item.slug === tool.slug))
  .slice(0, Math.max(0, 18 - featured.length));
const hubTools = [...featured, ...fillTools].slice(0, 30);
const relatedHubs = hub.relatedHubSlugs
  .map((slug) => toolHubs.find((item) => item.slug === slug))
  .filter((item): item is ToolHub => Boolean(item));
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": hub.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};
---
<BaseLayout
  title={hub.title}
  description={hub.description}
  canonical={`/tools/${hub.slug}/`}
  schema={[faqSchema]}
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a><span class="sep">/</span>
        <a href="/tools/">Tools</a><span class="sep">/</span>
        <span>{hub.h1}</span>
      </div>
      <span class="section-badge">TapToGen Hub</span>
      <h1>{hub.h1}</h1>
      <p>{hub.intro}</p>
      <div class="tool-benefits" aria-label="Hub benefits" style="justify-content:center;margin-top:24px;">
        <span>{hubTools.length} curated tools</span>
        <span>Indexable active tools</span>
        <span>FAQs and next steps</span>
      </div>
    </div>
  </section>

  <section class="tools-section" style="padding-top:0;">
    <div class="container">
      <div class="content-section" style="margin-bottom:32px;">
        <h2>Start With These Tools</h2>
        <p>{hub.description}</p>
        <p>Every tool linked from this hub is active and kept out of TapToGen's noindex safety list, so the hub stays focused on public discovery pages rather than redirected, removed, or risk-sensitive utilities.</p>
      </div>

      <div class="tools-grid">
        {hubTools.map((tool) => (
          <a href={`/tools/${tool.slug}/`} class="tool-card">
            <div class="tool-icon">{tool.icon}</div>
            <h3>{tool.name}</h3>
            <p>{tool.tagline}</p>
            <span class="tool-tag">{tool.category}</span>
          </a>
        ))}
      </div>

      <div class="content-section">
        <h2>How to Use This Hub</h2>
        <p>Pick the closest tool first, generate a few drafts, and compare the results for clarity, fit, originality, and practical use. For public projects, check availability, claims, platform rules, and any legal or brand requirements before publishing.</p>
        <p>Use the related hubs below when your task crosses topics. For example, a name can lead into a business name, a writing draft can lead into SEO metadata, and a creative prompt can lead into title or character work.</p>
        <h2>Frequently Asked Questions</h2>
        {hub.faqs.map((faq) => (
          <>
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </>
        ))}
      </div>

      {relatedHubs.length > 0 && (
        <div style="margin-top:40px;">
          <h2 style="text-align:center;margin-bottom:24px;">Related TapToGen Hubs</h2>
          <div class="category-grid">
            {relatedHubs.map((relatedHub) => (
              <a href={`/tools/${relatedHub.slug}/`} class="category-card">
                <span class="cat-icon">#</span>
                <h3>{relatedHub.h1}</h3>
                <p>{relatedHub.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
