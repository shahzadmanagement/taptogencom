---
interface Props {
  shortcuts: boolean;
}
const { shortcuts } = Astro.props;
---
{shortcuts && (
  <div class="shortcut-legend" style="margin-top: 12px; margin-bottom: 8px; padding: 8px 12px; background: rgba(255,255,255,0.02); border: 1px dashed var(--color-border); border-radius: 6px; font-size: 0.7rem; color: var(--color-text-secondary); display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
    <span>💡 <strong>Esc</strong> to clear</span>
    <span><strong>Alt+S</strong> to shuffle</span>
    <span><strong>Alt+R</strong> to copy random</span>
  </div>
)}
