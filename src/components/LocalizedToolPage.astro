  benefits: ['Free', 'Instant', 'No signup', 'Private in your browser'],
  inputKicker: 'Input',
  customize: 'Customize the result',
  enabled: 'Enabled',
  tone: 'Tone',
  tones: ['Balanced', 'Polished', 'Creative', 'Friendly'],
  count: 'Count',
  inputLabel: 'Prompt, keyword, text, or details',
  placeholder: 'Enter a keyword, prompt, or text to customize this generator...',
  examples: 'Examples',
