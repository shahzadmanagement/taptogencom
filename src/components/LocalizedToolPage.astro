  customize: 'Customize the result',
  enabled: 'Enabled',
  tone: 'Tone',
  tones: ['Balanced', 'Polished', 'Creative', 'Friendly'],
  count: 'Count',
  inputLabel: 'Prompt, keyword, text, or details',
  placeholder: 'Enter a keyword, prompt, or text to customize this generator...',
  examples: 'Examples',
  generate: 'Generate',
  example: 'Use example',
  reset: 'Clear',
  regenerate: 'Regenerate',
  outputKicker: 'Output',
  outputTitle: 'Your results',
  copyAll: 'Copy all',
  empty: 'Your results will appear here.',
  note: 'Note:',
  whatIs: 'What is',
  howTo: 'How to use',
  tips: 'Tips for better results',
  why: 'Why use TapToGen?',
  whyItems: [],
  faq: 'FAQ',
  related: 'Related tools',
  explore: 'Explore more TapToGen tools',
  activeLinks: 'These links lead to active, indexable tools.',
  benefitsTitle: 'Key Benefits',
  benefitsList: [
    '<strong>100% Free</strong> - No subscriptions, no microtransactions, and no credit card required.',
    '<strong>Browser-Based Privacy</strong> - All processing occurs locally on your machine. Your data never leaves your browser.',
    '<strong>Instant Generation</strong> - Get a list of optimized suggestions in milliseconds.',
    '<strong>No Registration</strong> - Start using the utility immediately without creating an account or logging in.'
  ],
  featuresTitle: 'Features of {name}',
  featuresList: [
    '<strong>Interactive Settings</strong> - Customize the tone, count, and style configuration directly from the control panel.',
    '<strong>One-Click Copying</strong> - Copy individual elements or copy all results instantly with built-in clipboard actions.',
    '<strong>Clean Formatting</strong> - Outputs copy-ready text without any markup, ready to be pasted anywhere.'
  ],
  bestPracticesTitle: 'Best Practices & Common Mistakes',
  bestPracticesHeading: 'Best Practices',
  bestPracticesList: [
    '<strong>Provide Clear Input</strong> - Give as much context as possible in the input box for highly relevant results.',
    '<strong>Explore Different Styles</strong> - Try changing options like tone or structure to find the perfect output.',
    '<strong>Review and Polish</strong> - Treat the generated output as a high-quality draft and review it for factual alignment before publishing.'
  ],
  commonMistakesHeading: 'Common Mistakes to Avoid',
  commonMistakesList: [
    '<strong>Vague Inputs</strong> - Entering single-word, generic inputs can result in less specialized suggestions.',
    '<strong>Skipping Review</strong> - Not verifying custom names, tags, or text before publishing can lead to policy or branding conflicts.',
    '<strong>Ignoring Settings</strong> - Forgetting to toggle tone or formatting options can cause output misalignment.'
  ],
  ctaTitle: 'Try {name} Now!',
  ctaBody: 'Ready to optimize your workflow? Try {name} now. Simply scroll back up to the interactive console, enter your details, and tap generate to get started immediately!',
  ctaBtn: 'Go to Generator'
};

const internalLinks = getInternalLinks(Astro.url.pathname, language);
const matchingHub = toolHubs.find((hub) => hub.slug === tool.categorySlug || hub.categorySlugs.includes(tool.categorySlug));
const nextStepHubs = toolHubs
  .filter((hub) => hub.slug !== matchingHub?.slug && (matchingHub?.relatedHubSlugs.includes(hub.slug) || hub.relatedHubSlugs.includes(matchingHub?.slug || '')))
  .slice(0, 3);

const faqItems = createLocalizedFaqItems(localized);
const guideCopy = createLocalizedGuide(tool, localized);
const copy = getLocalizedPageCopy(localized);
const safetyNote = getLocalizedSafetyNote(localized);
const languageConfig = getSupportedLanguage(language);
const englishRoute = getLanguageSwitchRoute(slug, 'en');
const localizedRoute = getLanguageSwitchRoute(slug, language);
const alternates = getToolLanguageAlternates(slug);
const pass20Controls = pass20ControlMap[slug];

const toolSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: copy.h1,
  url: `https://taptogen.com${localizedRoute}`,
  description: copy.metaDescription,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  browserRequirements: 'Requires JavaScript',
  inLanguage: language,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: text.home, item: `https://taptogen.com/${language}/` },
    { '@type': 'ListItem', position: 2, name: text.tools, item: `https://taptogen.com/${language}/tools/` },
    { '@type': 'ListItem', position: 3, name: copy.h1, item: `https://taptogen.com${localizedRoute}` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: language,
  mainEntity: faqItems.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbs = getBreadcrumbs(Astro.url.pathname, language, copy.h1);
---
<BaseLayout
  title={copy.metaTitle}
  description={copy.metaDescription}
  canonical={localizedRoute}
  schema={[toolSchema, breadcrumbSchema, faqSchema]}
  noindex={false}
  lang={language}
  dir={languageConfig.dir}
  alternates={alternates}
>
  <section class="tool-page">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
          {breadcrumbs.map((item, idx) => (
            <>
              {idx > 0 && <span class="sep">/</span>}
              <li>
                {item.isActive ? (
                  <span>{item.name}</span>
                ) : (
                  <a href={item.url}>{item.name}</a>
                )}
              </li>
            </>
          ))}
        </ol>
      </nav>

      <div class="tool-page-header premium-tool-header">
        <span class="section-badge tool-category-badge">{tool.icon} {getLocalizedUiLabel(tool.category, language)}</span>
        <h1>{copy.h1}</h1>
        <p>{copy.intro}</p>
        <nav class="language-switcher" aria-label={text.languageSwitcher}>
          <a href={englishRoute} hreflang="en" lang="en">English</a>
          {localizedPilotLanguages.map((item) => (
            <a class={item === language ? 'active' : ''} href={getLanguageSwitchRoute(slug, item)} hreflang={item} lang={item}>{getSupportedLanguage(item).nativeName}</a>
          ))}
        </nav>
        <div class="tool-benefits" aria-label={text.benefitsLabel}>
          {text.benefits.map((benefit) => <span>{benefit}</span>)}
        </div>
      </div>

      <div class="tool-workspace premium-tool-workspace" id="tool-workspace" data-tool={tool.slug} data-type={tool.generatorType} data-format={tool.outputFormat || 'text'}>
        <div id="generator-ui">
          <div class="workspace-panel input-panel">
            <div class="panel-heading">
              <div>
                <span class="panel-kicker">{text.inputKicker}</span>
                <h2>{text.customize}</h2>
              </div>
              <span class="generator-type-pill">{getLocalizedUiLabel(tool.generatorType.replace('-', ' '), language)}</span>
            </div>

            {tool.toolOptions && tool.toolOptions.length > 0 && (
              <div class="tool-options-panel">
                {tool.toolOptions.map((opt) => (
                  <div class="tool-option">
                    <label for={opt.id}>{getLocalizedUiLabel(opt.label, language)}</label>
                    {opt.type === 'select' && (
                      <select id={opt.id} class="tool-select">
                        {opt.options?.map((o) => (
                          <option value={o.value} selected={o.value === opt.default}>{getLocalizedUiLabel(o.label, language)}</option>
                        ))}
                      </select>
                    )}
                    {opt.type === 'number' && (
                      <input type="number" id={opt.id} class="tool-number" value={typeof opt.default === 'number' || typeof opt.default === 'string' ? opt.default : undefined} min={opt.min} max={opt.max} />
                    )}
                    {opt.type === 'checkbox' && (
                      <div class="checkbox-option">
                        <input type="checkbox" id={opt.id} class="tool-checkbox" checked={!!opt.default} />
                        <span>{text.enabled}</span>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}

            {pass20Controls && (
              <div class="tool-options-panel">
                <div class="tool-option">
                  <label for={pass20Controls.modeId}>{getLocalizedUiLabel(pass20Controls.modeLabel, language)}</label>
                  <select id={pass20Controls.modeId} class="tool-select">
                    {pass20Controls.modes.map((option) => (
                      <option value={option.value}>{getLocalizedUiLabel(option.label, language)}</option>
                    ))}
                  </select>
                </div>
                {pass20Controls.toneId && (
                  <div class="tool-option">
                    <label for={pass20Controls.toneId}>{text.tone}</label>
                    <select id={pass20Controls.toneId} class="tool-select">
                      <option value="balanced">{text.tones[0]}</option>
                      <option value="polished">{text.tones[1]}</option>
                      <option value="creative">{text.tones[2]}</option>
                      <option value="friendly">{text.tones[3]}</option>
                    </select>
                  </div>
                )}
                {pass20Controls.countId && (
                  <div class="tool-option">
                    <label for={pass20Controls.countId}>{text.count}</label>
                    <input type="number" id={pass20Controls.countId} class="tool-number" value={pass20Controls.countDefault} min={pass20Controls.countMin} max={pass20Controls.countMax} />
                  </div>
                )}
              </div>
            )}

            <label class="input-label" for="tool-input">{text.inputLabel}</label>
            {toolConfig && (toolConfig.counters.chars || toolConfig.counters.glyphs || toolConfig.counters.words || toolConfig.counters.lines) && (
              <div class="casing-toolbar" style="margin-bottom: 8px; display: flex; gap: 8px; flex-wrap: wrap; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--color-border); padding-bottom: 8px;">
                <div style="display: flex; gap: 6px;">
                  <button type="button" class="btn btn-ghost" id="btn-case-lower" style="padding: 4px 8px; font-size: 0.75rem; border-radius: 4px; font-weight: 500; min-height: 28px;">lowercase</button>
                  <button type="button" class="btn btn-ghost" id="btn-case-upper" style="padding: 4px 8px; font-size: 0.75rem; border-radius: 4px; font-weight: 500; min-height: 28px;">UPPERCASE</button>
                  <button type="button" class="btn btn-ghost" id="btn-case-title" style="padding: 4px 8px; font-size: 0.75rem; border-radius: 4px; font-weight: 500; min-height: 28px;">Title Case</button>
                  <button type="button" class="btn btn-ghost" id="btn-case-sentence" style="padding: 4px 8px; font-size: 0.75rem; border-radius: 4px; font-weight: 500; min-height: 28px;">Sentence case</button>
                  {toolConfig.slug === 'fancy-text-generator' && (
                    <button type="button" class="btn btn-ghost" id="btn-case-random-style" style="padding: 4px 8px; font-size: 0.75rem; border-radius: 4px; font-weight: 500; min-height: 28px; color: var(--color-accent-2);">🎲 Random</button>
                  )}
                </div>
                <MetricsPanel chars={toolConfig.counters.chars} glyphs={toolConfig.counters.glyphs} words={toolConfig.counters.words} lines={toolConfig.counters.lines} />
              </div>
            )}
            <textarea class="tool-input" id="tool-input" placeholder={text.placeholder} rows="4"></textarea>
            <div class="example-chip-row" aria-label={text.examples}>
              <button type="button" class="example-chip" data-example={copy.primaryKeyword}>{copy.primaryKeyword}</button>
              {copy.faqTopics.slice(0, 2).map((keyword) => (
                <button type="button" class="example-chip" data-example={keyword}>{keyword}</button>
              ))}
            </div>
            {toolConfig && toolConfig.shortcuts && (
              <KeyboardShortcuts shortcuts={toolConfig.shortcuts} />
            )}
            <div class="tool-controls premium-controls">
              <button class="btn btn-primary" id="generate-btn">{text.generate}</button>
              <button class="btn btn-outline" id="example-btn">{text.example}</button>
              <button class="btn btn-ghost" id="reset-btn">{text.reset}</button>
              <button class="btn btn-ghost" id="regenerate-btn">{text.regenerate}</button>
            </div>
          </div>

          <div class="workspace-panel output-panel">
            <div class="panel-heading">
              <div>
                <span class="panel-kicker">{text.outputKicker}</span>
                <h2>{text.outputTitle}</h2>
              </div>
              <button class="copy-btn copy-all-btn" id="copy-btn">{text.copyAll}</button>
            </div>
            {toolConfig && (toolConfig.search || toolConfig.exporters.length > 0) && (
              <div class="style-search-container" style="margin-bottom: 12px; display: none;" id="style-search-container">
                <div style="display: flex; gap: 8px; align-items: center; width: 100%; flex-wrap: wrap;">
                  {toolConfig.search && (
                    <input type="text" id={`${toolConfig.slug.split('-')[0]}-style-search`} placeholder={`Search ${toolConfig.slug === 'fancy-text-generator' ? '50+' : ''} styles...`} style="flex: 1; min-width: 200px; padding: 8px 12px; border-radius: 8px; border: 1px solid var(--color-border); background: var(--color-bg-secondary); color: var(--color-text-primary); font-size: 0.85rem; outline: none; transition: var(--transition);" />
                  )}
                  {toolConfig.shuffle && (
                    <button type="button" class="btn btn-ghost" id="btn-shuffle-styles" style="padding: 8px 12px; font-size: 0.8rem; border-radius: 8px; min-height: 35px; white-space: nowrap;">🔀 Shuffle</button>
                  )}
                  <DownloadToolbar exporters={toolConfig.exporters} />
                </div>
              </div>
            )}
            <div class="tool-output premium-output empty" id="tool-output">{text.empty}</div>
            {toolConfig && (toolConfig.previews.length > 0 || toolConfig.history) && (
              <div class={`${toolConfig.slug.split('-')[0]}-premium-extensions`} style="display: none;" id={`${toolConfig.slug.split('-')[0]}-extensions-container`}>
                <PreviewTabs previews={toolConfig.previews} placeholder={toolConfig.slug === 'fancy-text-generator' ? 'Your fancy text...' : 'Your bold text...'} />
                <HistoryPanel enabled={toolConfig.history} prefix={toolConfig.slug.split('-')[0]} />
              </div>
            )}
          </div>
        </div>
      </div>

      {safetyNote && (
        <div class="tool-disclaimer" style="margin-top: 15px; padding: 15px; background: rgba(255, 193, 7, 0.1); border-left: 4px solid #ffc107; border-radius: 4px; font-size: 0.9rem; color: #b8860b;">
          <strong>{text.note}</strong> {safetyNote}
        </div>
      )}

      <div class="content-section premium-content-section">
        <IntroSection h1={copy.h1} metaDescription={copy.metaDescription} intro={copy.intro} whatIsText={text.whatIs} />

        <section class="content-card">
          <h2>{text.benefitsTitle}</h2>
          <ul>
            {text.benefitsList.map((benefit) => <li set:html={benefit} />)}
          </ul>
        </section>

        <section class="content-card">
          <h2>{text.featuresTitle.replace('{name}', copy.h1)}</h2>
          <ul>
            {text.featuresList.map((feature) => <li set:html={feature} />)}
          </ul>
        </section>

        <section class="content-card">
          <h2>{text.howTo} {copy.h1}</h2>
          <ol>
            {guideCopy.howTo.map((step) => <li>{step}</li>)}
          </ol>
        </section>

        <section class="content-card">
          <h2>{text.tips}</h2>
          <ul>
            {guideCopy.tips.map((tip) => <li><strong>{tip.title}</strong> - {tip.body}</li>)}
          </ul>
        </section>

        <section class="content-card">
          <h2>{text.bestPracticesTitle}</h2>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-top: 12px; margin-bottom: 6px; color: var(--color-text-primary);">{text.bestPracticesHeading}</h3>
          <ul>
            {text.bestPracticesList.map((item) => <li set:html={item} />)}
          </ul>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-top: 16px; margin-bottom: 6px; color: var(--color-text-primary);">{text.commonMistakesHeading}</h3>
          <ul>
            {text.commonMistakesList.map((item) => <li set:html={item} />)}
          </ul>
        </section>

        <section class="content-card" style="text-align: center; padding: 30px;">
          <h2>{text.ctaTitle.replace('{name}', copy.h1)}</h2>
          <p style="margin-bottom: 16px;">{text.ctaBody.replace('{name}', copy.h1)}</p>
          <a href="#" class="btn btn-primary" style="display: inline-block; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 600; color: #fff; background: var(--color-primary);">{text.ctaBtn}</a>
        </section>

        <section class="content-card">
          <h2>{text.why}</h2>
          <ul>
            {text.whyItems.map((item) => <li><strong>{item[0]}</strong> - {item[1]}</li>)}
          </ul>
        </section>

        <FaqSection faqTitle={text.faq} faqItems={faqItems.map(f => ({ question: f.q, answer: f.a }))} />
      </div>
      <RelatedSection title={text.related} links={internalLinks.slice(0, 4)} />
      {internalLinks.length > 4 && (
        <RelatedSection title="You May Also Like" links={internalLinks.slice(4, 8)} />
      )}

      {(matchingHub || nextStepHubs.length > 0) && (
        <section class="content-card">
          <h2>{text.explore}</h2>
          <p>{text.activeLinks}</p>
          <div class="category-grid">
            {matchingHub && (
              <a href={`/tools/${matchingHub.slug}/`} class="category-card">
                <span class="cat-icon">#</span>
                <h3>{getLocalizedHubCopy(matchingHub.slug, matchingHub.h1, matchingHub.description, language).title}</h3>
                <p>{getLocalizedHubCopy(matchingHub.slug, matchingHub.h1, matchingHub.description, language).description}</p>
              </a>
            )}
            {nextStepHubs.map((hub) => (
              <a href={`/tools/${hub.slug}/`} class="category-card">
                <span class="cat-icon">#</span>
                <h3>{getLocalizedHubCopy(hub.slug, hub.h1, hub.description, language).title}</h3>
                <p>{getLocalizedHubCopy(hub.slug, hub.h1, hub.description, language).description}</p>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>      </div>
    </div>
  </section>

  <script>
    import '@/scripts/tool-workspace';
  </script>
</BaseLayout>
