---
import type { Tool } from '../data/tools';
import { getToolRoute } from '../data/localization';

interface Props {
  title: string;
  relatedTools?: Tool[];
  links?: { url: string; anchor: string; icon: string }[];
  isSpanish?: boolean;
}

const { title, relatedTools = [], links, isSpanish = false } = Astro.props;

const resolvedLinks = links || relatedTools.map(item => ({
  url: getToolRoute(item.slug, isSpanish ? 'es' : 'en'),
  anchor: item.name,
  icon: item.icon
}));
---

{resolvedLinks && resolvedLinks.length > 0 && (
  <section class="content-card related-card">
    <h2>{title}</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; margin-top: 16px;">
      {resolvedLinks.map(item => (
        <a href={item.url} style="padding: 14px; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; background: rgba(255,255,255,0.02); display: flex; align-items: center; gap: 8px; transition: var(--transition); color: var(--color-text-primary);" class="related-tool-link">
          <span style="font-size: 1.25rem;">{item.icon}</span>
          <div>
            <div style="font-weight: 600; font-size: 0.88rem;">{item.anchor}</div>
          </div>
        </a>
      ))}
    </div>
  </section>
)}
