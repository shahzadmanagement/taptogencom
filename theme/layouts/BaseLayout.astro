---
import { siteConfig } from '@/config/site';
import { headerNav, footerNav } from '@/data/navigation';
import { getSupportedLanguage } from '@/data/localization';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object[];
  noindex?: boolean;
  lang?: string;
  dir?: 'ltr' | 'rtl';
  alternates?: { lang: string; href: string }[];
}

const { title, description, canonical, ogImage, schema = [], noindex = false, lang = 'en', dir = 'ltr', alternates = [] } = Astro.props;
const canonicalUrl = canonical ? `${siteConfig.url}${canonical}` : `${siteConfig.url}${Astro.url.pathname}`;
const ogImg = ogImage || `${siteConfig.url}${siteConfig.defaultOgImage}`;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteConfig.name,
  "url": siteConfig.url,
  "description": siteConfig.description,
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${siteConfig.url}/tools/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": siteConfig.name,
  "url": siteConfig.url,
  "logo": `${siteConfig.url}/favicon.svg`,
  "contactPoint": {
    "@type": "ContactPoint",
    "email": siteConfig.contactEmail,
    "contactType": "customer support"
  }
};

const allSchemas = [websiteSchema, orgSchema, ...schema];
const currentPath = Astro.url.pathname;
const isSpanish = lang === 'es';
const navLabelMap: Record<string, string> = {
  '/': 'Inicio',
  '/tools/': 'Herramientas',
  '/categories/': 'Categorías',
  '/blog/': 'Blog',
  '/about-us/': 'Acerca de',
};
const footerLabelMap: Record<string, string> = {
  '/tools/name-generators/': 'Generadores de nombres',
  '/tools/text-generators/': 'Generadores de texto',
  '/tools/writing-generators/': 'Generadores de escritura',
  '/tools/seo-generators/': 'Generadores SEO',
  '/tools/business-generators/': 'Generadores para negocios',
  '/tools/creative-generators/': 'Generadores creativos',
  '/tools/fancy-text-generator/': 'Generador de letras bonitas',
  '/tools/name-generator/': 'Generador de nombres',
  '/tools/username-generator/': 'Generador de nombres de usuario',
  '/tools/bio-generator/': 'Generador de biografías',
  '/tools/youtube-tag-generator/': 'Generador de etiquetas para videos',
  '/tools/business-name-generator/': 'Generador de nombres para empresas',
  '/about-us/': 'Acerca de',
  '/contact-us/': 'Contacto',
  '/privacy/': 'Privacidad',
  '/terms/': 'Términos',
  '/disclaimer/': 'Aviso legal',
  '/sitemap/': 'Mapa del sitio',
};
const localizeLabel = (href: string, label: string) => isSpanish ? (footerLabelMap[href] || navLabelMap[href] || label) : label;
---
<!DOCTYPE html>
<html lang={lang} dir={dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {alternates.map((alternate) => (
    <link rel="alternate" hreflang={alternate.lang} href={alternate.href} />
  ))}
  <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
  <meta name="googlebot" content={noindex ? 'noindex, follow' : 'index, follow'} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteConfig.name} />
  <meta property="og:image" content={ogImg} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImg} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  {siteConfig.verification.google && <meta name="google-site-verification" content={siteConfig.verification.google} />}
  {siteConfig.verification.bing && <meta name="msvalidate.01" content={siteConfig.verification.bing} />}
  {allSchemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
  <style is:global>
    @import '../styles/global.css';
    
    /* First-class Navigation Dropdown Styles */
    .nav-item-dropdown {
      position: relative;
      display: inline-block;
    }
    
    .nav-dropdown-toggle {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      font-size: 16px;
      font-weight: 500;
      color: var(--text-color, #2d3748);
      background: transparent;
      border: none;
      cursor: pointer;
      font-family: inherit;
      transition: color 0.2s;
      line-height: inherit;
    }
    
    .nav-dropdown-toggle:hover,
    .nav-item-dropdown:hover .nav-dropdown-toggle,
    .nav-dropdown-toggle:focus {
      color: var(--primary-color, #4f46e5);
      outline: none;
    }
    
    .dropdown-chevron {
      font-size: 8px;
      margin-left: 2px;
      opacity: 0.7;
      transition: transform 0.2s;
    }
    
    .nav-item-dropdown:hover .dropdown-chevron {
      transform: rotate(180deg);
    }
    
    .nav-dropdown-menu {
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%) translateY(8px);
      background-color: #1a202c; /* Dark theme matching the footer/dark layout */
      min-width: 180px;
      border-radius: 8px;
      padding: 8px 0;
      margin: 0;
      list-style: none;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3), 0 4px 6px -2px rgba(0, 0, 0, 0.15);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.2s, visibility 0.2s, transform 0.2s;
      z-index: 1000;
    }
    
    .nav-item-dropdown:hover .nav-dropdown-menu,
    .nav-item-dropdown:focus-within .nav-dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }
    
    .nav-dropdown-menu li {
      margin: 0;
      padding: 0;
    }
    
    .nav-dropdown-menu a {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 16px;
      font-size: 14px;
      color: #e2e8f0;
      text-decoration: none;
      font-weight: 500;
      transition: background-color 0.2s, color 0.2s;
      border: none;
      background: transparent;
      text-align: left;
    }
    
    .nav-dropdown-menu a:hover,
    .nav-dropdown-menu a:focus {
      background-color: #2d3748;
      color: #ffffff;
      outline: none;
    }
    
    .nav-dropdown-menu a.active-lang {
      color: var(--primary-color, #4f46e5);
      font-weight: 600;
    }
    
    .lang-check {
      font-size: 12px;
      font-weight: bold;
      color: var(--primary-color, #4f46e5);
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border-width: 0;
    }

    @media (max-width: 768px) {
      .nav-item-dropdown {
        display: block;
        width: 100%;
      }
      
      .nav-dropdown-toggle {
        width: 100%;
        padding: 10px 16px;
        justify-content: space-between;
        font-size: 18px; /* Match standard mobile menu list font size */
      }
      
      .nav-dropdown-menu {
        position: static;
        transform: none;
        background-color: rgba(0, 0, 0, 0.05);
        box-shadow: none;
        width: 100%;
        max-height: 0;
        overflow: hidden;
        padding: 0;
        opacity: 1;
        visibility: visible;
        transition: max-height 0.3s ease-out;
      }
      
      .nav-item-dropdown:hover .nav-dropdown-menu,
      .nav-item-dropdown:focus-within .nav-dropdown-menu,
      .nav-item-dropdown.mobile-open .nav-dropdown-menu {
        max-height: 500px;
        padding: 8px 0;
      }
      
      .nav-dropdown-menu a {
        padding: 10px 24px;
        color: var(--text-color, #2d3748);
      }
      
      .nav-dropdown-menu a:hover {
        background-color: rgba(0, 0, 0, 0.02);
      }
    }
  </style>
</head>
<body>
  <!-- Header -->
  <nav class="nav" id="main-nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <span class="logo-icon">⚡</span>
        {siteConfig.name}
      </a>
      <div class="nav-links" id="nav-links" role="navigation" aria-label={isSpanish ? 'Navegación principal' : 'Main navigation'}>
        <a href="/" class={currentPath === '/' ? 'active' : ''}>{localizeLabel('/', 'Home')}</a>
        <a href="/tools/" class={currentPath === '/tools/' || (currentPath.startsWith('/tools/') && currentPath !== '/tools/categories/') ? 'active' : ''}>{localizeLabel('/tools/', 'Tools')}</a>
        <a href="/categories/" class={currentPath === '/categories/' || currentPath.startsWith('/categories/') ? 'active' : ''}>{localizeLabel('/categories/', 'Categories')}</a>
        
        {alternates && alternates.length > 0 && (
          <div class="nav-item-dropdown" id="language-dropdown">
            <button 
              class="nav-dropdown-toggle" 
              aria-haspopup="true" 
              aria-expanded="false"
              aria-label="Select Language"
            >
              <span>🌐 Language</span>
              <span class="dropdown-chevron" aria-hidden="true">▼</span>
            </button>
            <ul class="nav-dropdown-menu" role="menu" aria-label="Languages">
              {alternates
                .filter(alt => alt.lang !== 'x-default')
                .map((alternate) => (
                  <li role="none">
                    <a 
                      href={alternate.href.replace(siteConfig.url, '')}
                      role="menuitem"
                      class={alternate.lang === lang ? 'active-lang' : ''}
                    >
                      <span class="lang-name">
                        {alternate.lang === 'en' ? 'English' : getSupportedLanguage(alternate.lang).nativeName}
                      </span>
                      {alternate.lang === lang && <span class="lang-check" aria-hidden="true">✓</span>}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        )}

        <a href="/blog/" class={currentPath === '/blog/' || currentPath.startsWith('/blog/') ? 'active' : ''}>{localizeLabel('/blog/', 'Blog')}</a>
        <a href="/about-us/" class={currentPath === '/about-us/' || currentPath.startsWith('/about-us/') ? 'active' : ''}>{localizeLabel('/about-us/', 'About')}</a>
      </div>
      <button class="mobile-toggle" id="mobile-toggle" aria-label={isSpanish ? 'Abrir menú' : 'Toggle menu'} aria-expanded="false">☰</button>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="nav-logo">
            <span class="logo-icon">⚡</span>
            {siteConfig.name}
          </a>
          <p>{isSpanish ? 'TapToGen ofrece generadores online gratuitos para crear nombres, texto, etiquetas, ideas SEO y borradores útiles con revisión humana antes de publicar.' : siteConfig.description}</p>
        </div>
        <div class="footer-col">
          <h4>{isSpanish ? 'Categorías' : 'Categories'}</h4>
          {footerNav.categories.map(item => (
            <a href={item.href}>{localizeLabel(item.href, item.label)}</a>
          ))}
        </div>
        <div class="footer-col">
          <h4>{isSpanish ? 'Herramientas populares' : 'Popular Tools'}</h4>
          {footerNav.popular.map(item => (
            <a href={item.href}>{localizeLabel(item.href, item.label)}</a>
          ))}
        </div>
        <div class="footer-col">
          <h4>{isSpanish ? 'Empresa' : 'Company'}</h4>
          {footerNav.legal.map(item => (
            <a href={item.href}>{localizeLabel(item.href, item.label)}</a>
          ))}
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; {new Date().getFullYear()} {siteConfig.name}.com — {isSpanish ? 'Todos los derechos reservados.' : 'All rights reserved.'}</span>
        <span>{isSpanish ? 'Creado para personas que necesitan generar ideas con criterio' : 'Built with ❤️ for creators everywhere'}</span>
      </div>
    </div>
  </footer>

  <script>
    const nav = document.getElementById('main-nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('scrolled', window.scrollY > 40);
    });

    const dropdown = document.getElementById('language-dropdown');
    const dropdownToggle = dropdown?.querySelector('.nav-dropdown-toggle');
    dropdownToggle?.addEventListener('click', (e) => {
      if (window.innerWidth <= 768) {
        e.preventDefault();
        const isOpen = dropdown.classList.toggle('mobile-open');
        dropdownToggle.setAttribute('aria-expanded', String(isOpen));
      }
    });

    const toggle = document.getElementById('mobile-toggle');
    const links = document.getElementById('nav-links');
    toggle?.addEventListener('click', () => {
      const isOpen = links?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    links?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        links.classList.remove('open');
        toggle?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('animate-in'); observer.unobserve(e.target); }});
    }, { threshold: 0.1 });
    document.querySelectorAll('.tool-card, .feature-card, .category-card, .step-card, .faq-item').forEach(el => observer.observe(el));
  </script>
</body>
</html>
